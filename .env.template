# ==========================================
# Medusa Backend Configuration
# ==========================================
# Medusa backend URL (include protocol and port)
# Example: http://localhost:9000
NEXT_PUBLIC_MEDUSA_BACKEND_URL=

# Medusa publishable API key (from Medusa admin/settings)
# Example: pk_1234567890abcdef
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=

# ==========================================
# Stripe Configuration (Frontend)
# ==========================================
# Stripe publishable key for client-side payment flow.
# Use Test Mode key during development.
# Example: pk_test_51...
NEXT_PUBLIC_STRIPE_KEY=

# ==========================================
# Crisp Chat Configuration (Optional)
# ==========================================
# Crisp Website ID for live chat integration.
# Leave empty if Crisp is not enabled.
# Example: xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
NEXT_PUBLIC_CRISP_WEBSITE_ID=

# ==========================================
# Frontend Base URL
# ==========================================
# Public base URL of this storefront.
# Example: http://localhost:8000
NEXT_PUBLIC_BASE_URL=
